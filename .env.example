# ─── EC2 / Docker deployment ───
BACKEND_IMAGE=<aws_account_id>.dkr.ecr.ap-south-1.amazonaws.com/acc-uw-backend:latest
FRONTEND_IMAGE=<aws_account_id>.dkr.ecr.ap-south-1.amazonaws.com/acc-uw-frontend:latest
COOKIE_DOMAIN=                    # e.g. .yourdomain.com — leave blank if no custom domain

# ACC Health Insurance UW Automation Platform v2.0 — Environment Variables
# Copy to .env and fill in actual values

# ─── Server ───
NODE_ENV=production
PORT=10000

# ─── Anthropic (Claude API for OCR/NLP extraction) ───
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── AWS S3 (Assessment & Document Storage) ───
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=ap-south-1
S3_BUCKET=acc-insurance-uw

# ─── Redis (BullMQ async processing queue) ───
REDIS_URL=rediss://red-xxxxx:6379

# ─── Microsoft Entra ID (O365 SSO) ───
AZURE_AD_CLIENT_ID=xxxxx-xxxxx-xxxxx
AZURE_AD_CLIENT_SECRET=xxxxx
AZURE_AD_TENANT_ID=xxxxx-xxxxx-xxxxx
AZURE_AD_REDIRECT_URI=https://insuranceuwapi.acc.ltd/auth/callback

# ─── Session ───
SESSION_SECRET=generate-a-random-64-char-string

# ─── Auth ───
SUPER_ADMIN_EMAIL=nilesh@acc.ltd
SKIP_AUTH=true

# ─── URLs ───
BASE_URL=https://insuranceuwapi.acc.ltd
FRONTEND_URL=https://insuranceuw.acc.ltd

# ─── Notes ───
# Vendor APIs: Dummy vendors are built-in (no external config needed)
# - VEND-001: MedCheck India (full PPHC)
# - VEND-002: HealthAssure (full PPHC)
# - VEND-003: DigiMedic (tele PPHC, video MER, face-scan)
# Set SKIP_AUTH=true for development/demo without Azure AD
# GitHub Actions secrets required: AWS_ACCOUNT_ID, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, EC2_HOST, EC2_USER, EC2_SSH_KEY
