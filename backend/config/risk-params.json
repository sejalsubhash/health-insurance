    "bmi_obese_2": { "min_bmi": 35, "max_bmi": 40, "loading_pct": 100 },
    "bmi_obese_3": { "min_bmi": 40, "loading_pct": -1, "action": "decline" },
    "smoker_current": { "loading_pct": 75 },
    "smoker_former_lt5": { "loading_pct": 25 },
    "hypertension_controlled": { "loading_pct": 25 },
    "hypertension_uncontrolled": { "loading_pct": 75 },
    "diabetes_controlled": { "loading_pct": 50 },
    "diabetes_uncontrolled": { "loading_pct": 100 },
    "cardiac_history": { "loading_pct": 100 },
    "cancer_remission_gt5yr": { "loading_pct": 50 },
    "cancer_remission_lt5yr": { "loading_pct": -1, "action": "decline" }
  },
  "age_loading": {
    "18-35": { "loading_pct": 0, "label": "Young adult — standard rates" },
    "36-45": { "loading_pct": 0, "label": "Adult — standard rates" },
    "46-50": { "loading_pct": 10, "label": "Middle-aged — minor age loading" },
    "51-55": { "loading_pct": 25, "label": "Senior — moderate age loading" },
    "56-60": { "loading_pct": 50, "label": "Pre-retirement — significant age loading" },
    "61-65": { "loading_pct": 100, "label": "Elderly — high age loading" },
    "66+": { "loading_pct": -1, "action": "decline", "label": "Beyond entry age limit" }
  },
  "sum_assured_tiers": {
    "tier_1": { "max_sum": 2500000, "label": "Up to 25L", "scrutiny": "basic", "required_tests": ["blood_work"], "reinsurance": false },
    "tier_2": { "max_sum": 10000000, "label": "25L-1Cr", "scrutiny": "enhanced", "required_tests": ["blood_work", "ecg", "urine_analysis"], "reinsurance": false },
    "tier_3": { "max_sum": 50000000, "label": "1Cr-5Cr", "scrutiny": "full_pphc", "required_tests": ["blood_work", "ecg", "echo", "tmt", "urine_analysis", "chest_xray", "physical_exam"], "reinsurance": false },
    "tier_4": { "max_sum": 999999999, "label": "Above 5Cr", "scrutiny": "full_medical_reinsurance", "required_tests": ["blood_work", "ecg", "echo", "tmt", "usg_abdomen", "urine_analysis", "chest_xray", "physical_exam"], "reinsurance": true }
  },
  "loading_cap": { "max_loading_pct": 200, "action_above_cap": "decline" },
  "waiting_periods": {
    "diabetes": { "years": 4, "description": "Diabetes and related complications" },
    "hypertension": { "years": 4, "description": "Hypertension and cardiovascular events" },
    "cardiac": { "years": 4, "description": "All cardiac conditions and procedures" },
    "asthma": { "years": 2, "description": "Asthma and COPD related claims" },
    "thyroid": { "years": 2, "description": "Thyroid disorders" },
    "kidney": { "years": 4, "description": "Renal conditions" },
    "liver": { "years": 4, "description": "Hepatic conditions" },
    "cancer": { "years": 4, "description": "All cancer related claims" },
    "standard_ped": { "years": 3, "description": "Standard PED waiting period per IRDAI" }
  },
  "gender_thresholds": {
    "hemoglobin": { "male": { "low": 13.0, "normal_min": 13.5, "normal_max": 17.5 }, "female": { "low": 11.5, "normal_min": 12.0, "normal_max": 15.5 } },
    "creatinine": { "male": { "normal_max": 1.3 }, "female": { "normal_max": 1.1 } }
  },
  "age_bands": { "18-30": { "base_multiplier": 1.0 }, "31-40": { "base_multiplier": 1.1 }, "41-50": { "base_multiplier": 1.3 }, "51-60": { "base_multiplier": 1.6 }, "61-65": { "base_multiplier": 2.0 } },
  "sum_assured_thresholds": { "non_medical": { "max_age": 45, "max_sum": 2500000 }, "telemer_only": { "max_age": 50, "max_sum": 10000000 }, "pphc_required": { "min_sum": 10000001 }, "full_medical": { "min_sum": 50000000 } },
  "stp_eligibility_rules": {
    "version": "1.0.0",
    "description": "Hard knockouts and soft flags for STP fast-lane evaluation. Hard knockouts route to NSTP. Soft flags route to telemer. All clean → STP eligible.",
    "hard_knockouts": {
      "max_age": 45,
      "max_sum_assured": 2500000,
      "min_age": 18,
      "declared_pec_blocks_stp": true,
      "current_smoker_blocks_stp": true,
      "tobacco_chewing_current_blocks_stp": true,
      "occupation_hazard_min_block": "moderate",
      "bmi_low_threshold": 17,
      "bmi_high_threshold": 32,
      "alcohol_heavy_blocks_stp": true,
      "family_history_critical_blocks_stp": true,
      "prior_claims_blocks_stp": true,
      "blacklist_blocks_stp": true
    },
    "soft_flags_route_to_telemer": {
      "age_min": 46,
      "age_max": 50,
      "sum_assured_min": 2500001,
      "sum_assured_max": 10000000,
      "bmi_min": 28,
      "bmi_max": 32,
      "alcohol_regular": true,
      "former_smoker": true,
      "family_history_non_critical": true
    },
    "lightweight_score_min_for_stp": 85,
    "max_findings_severity_for_stp": "low"
  },
  "auto_decline_rules": [ { "condition": "hiv_positive", "action": "decline" }, { "condition": "active_cancer", "action": "decline" }, { "condition": "esrd_dialysis", "action": "decline" }, { "condition": "lvef_below_30", "action": "decline" }, { "condition": "fraud_detected", "action": "decline" } ],
  "retention_limits": { "life": { "per_life": 20000000, "catastrophe": 100000000 }, "health": { "per_life": 5000000, "catastrophe": 50000000 } }
}
