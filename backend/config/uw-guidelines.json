{
  "version": "2.0.0",
  "description": "Underwriting Guidelines — 50+ Rules (Enhanced)",
  "rules": [
    { "id": "UG001", "name": "BMI Upper Limit", "path": "physical_exam.bmi.value", "operator": "<", "threshold": 40, "action": "decline", "severity": "critical" },
    { "id": "UG002", "name": "Blood Pressure Systolic", "path": "physical_exam.blood_pressure.systolic.value", "operator": "<", "threshold": 180, "action": "decline", "severity": "critical" },
    { "id": "UG003", "name": "Fasting Glucose", "path": "blood_chemistry.fasting_glucose.value", "operator": "<", "threshold": 300, "action": "decline", "severity": "critical" },
    { "id": "UG004", "name": "HbA1c Critical", "path": "blood_chemistry.hba1c.value", "operator": "<", "threshold": 10, "action": "decline", "severity": "critical" },
    { "id": "UG005", "name": "Creatinine Critical", "path": "blood_chemistry.serum_creatinine.value", "operator": "<", "threshold": 3.0, "action": "decline", "severity": "critical" },
    { "id": "UG006", "name": "LVEF Minimum", "path": "cardiac.echo.lvef.value", "operator": ">", "threshold": 30, "action": "decline", "severity": "critical" },
    { "id": "UG007", "name": "HIV Status", "path": "blood_chemistry.hiv.value", "operator": "==", "threshold": "non_reactive", "action": "decline", "severity": "critical" },
    { "id": "UG008", "name": "HBsAg Status", "path": "blood_chemistry.hbsag.value", "operator": "==", "threshold": "non_reactive", "action": "refer", "severity": "high" },
    { "id": "UG009", "name": "Cotinine (Tobacco)", "path": "blood_chemistry.cotinine.value", "operator": "<", "threshold": 200, "action": "loading", "severity": "medium" },
    { "id": "UG010", "name": "ECG Normal", "path": "cardiac.ecg.overall_interpretation", "operator": "in", "threshold": ["normal", "borderline"], "action": "refer", "severity": "medium" },
    { "id": "UG011", "name": "Hemoglobin Minimum", "path": "hematology.hemoglobin.value", "operator": ">", "threshold": 8, "action": "refer", "severity": "high" },
    { "id": "UG012", "name": "Urine Protein", "path": "urine_analysis.protein.value", "operator": "in", "threshold": ["nil", "negative", "trace"], "action": "refer", "severity": "medium" },
    { "id": "UG013", "name": "Blood Pressure Diastolic", "path": "physical_exam.blood_pressure.diastolic.value", "operator": "<", "threshold": 110, "action": "decline", "severity": "critical" },
    { "id": "UG014", "name": "Fasting Glucose Pre-Diabetic", "path": "blood_chemistry.fasting_glucose.value", "operator": "<", "threshold": 126, "action": "loading", "severity": "medium" },
    { "id": "UG015", "name": "HbA1c Pre-Diabetic", "path": "blood_chemistry.hba1c.value", "operator": "<", "threshold": 6.5, "action": "loading", "severity": "medium" },
    { "id": "UG016", "name": "Total Cholesterol High", "path": "blood_chemistry.total_cholesterol.value", "operator": "<", "threshold": 300, "action": "loading", "severity": "medium" },
    { "id": "UG017", "name": "LDL Critical", "path": "blood_chemistry.ldl.value", "operator": "<", "threshold": 190, "action": "refer", "severity": "high" },
    { "id": "UG018", "name": "Triglycerides High", "path": "blood_chemistry.triglycerides.value", "operator": "<", "threshold": 400, "action": "refer", "severity": "high" },
    { "id": "UG019", "name": "SGPT/ALT Liver", "path": "blood_chemistry.sgpt_alt.value", "operator": "<", "threshold": 120, "action": "refer", "severity": "high" },
    { "id": "UG020", "name": "SGOT/AST Liver", "path": "blood_chemistry.sgot_ast.value", "operator": "<", "threshold": 120, "action": "refer", "severity": "high" },
    { "id": "UG021", "name": "Blood Urea High", "path": "blood_chemistry.blood_urea.value", "operator": "<", "threshold": 50, "action": "loading", "severity": "medium" },
    { "id": "UG022", "name": "Uric Acid High", "path": "blood_chemistry.uric_acid.value", "operator": "<", "threshold": 9, "action": "loading", "severity": "medium" },
    { "id": "UG023", "name": "Total Bilirubin", "path": "blood_chemistry.total_bilirubin.value", "operator": "<", "threshold": 2.5, "action": "refer", "severity": "high" },
    { "id": "UG024", "name": "Albumin Low", "path": "blood_chemistry.albumin.value", "operator": ">", "threshold": 3.2, "action": "refer", "severity": "high" },
    { "id": "UG025", "name": "ESR Elevated", "path": "hematology.esr.value", "operator": "<", "threshold": 40, "action": "loading", "severity": "medium" },
    { "id": "UG026", "name": "WBC Count High", "path": "hematology.wbc_count.value", "operator": "<", "threshold": 15000, "action": "loading", "severity": "medium" },
    { "id": "UG027", "name": "WBC Count Low", "path": "hematology.wbc_count.value", "operator": ">", "threshold": 3500, "action": "refer", "severity": "high" },
    { "id": "UG028", "name": "Platelet Count Low", "path": "hematology.platelet_count.value", "operator": ">", "threshold": 100000, "action": "refer", "severity": "high" },
    { "id": "UG029", "name": "Urine Glucose", "path": "urine_analysis.glucose.value", "operator": "in", "threshold": ["nil", "negative"], "action": "refer", "severity": "high" },
    { "id": "UG030", "name": "GGT Elevated", "path": "liver_extended.ggt.value", "operator": "<", "threshold": 100, "action": "loading", "severity": "medium" },
    { "id": "UG031", "name": "ALP Elevated", "path": "liver_extended.alp.value", "operator": "<", "threshold": 150, "action": "loading", "severity": "medium" },
    { "id": "UG032", "name": "TSH Abnormal High", "path": "thyroid.tsh.value", "operator": "<", "threshold": 10, "action": "loading", "severity": "medium" },
    { "id": "UG033", "name": "TSH Abnormal Low", "path": "thyroid.tsh.value", "operator": ">", "threshold": 0.4, "action": "loading", "severity": "medium" },
    { "id": "UG034", "name": "Chest X-Ray Abnormal", "path": "chest_xray.interpretation", "operator": "in", "threshold": ["normal", "no abnormality"], "action": "refer", "severity": "high" },
    { "id": "UG035", "name": "TMT Positive", "path": "cardiac_extended.tmt.result", "operator": "in", "threshold": ["negative", "normal"], "action": "refer", "severity": "high" },
    { "id": "UG036", "name": "LVEF Below Normal", "path": "cardiac_extended.lvef.value", "operator": ">", "threshold": 50, "action": "refer", "severity": "high" },
    { "id": "UG037", "name": "BMI Overweight Refer Age>55", "path": "physical_exam.bmi.value", "operator": "<", "threshold": 30, "action": "loading", "severity": "medium", "age_condition": ">55" },
    { "id": "UG038", "name": "BP Systolic Moderate", "path": "physical_exam.blood_pressure.systolic.value", "operator": "<", "threshold": 140, "action": "loading", "severity": "medium" },
    { "id": "UG039", "name": "BP Diastolic Moderate", "path": "physical_exam.blood_pressure.diastolic.value", "operator": "<", "threshold": 90, "action": "loading", "severity": "medium" },
    { "id": "UG040", "name": "HDL Too Low", "path": "blood_chemistry.hdl.value", "operator": ">", "threshold": 35, "action": "loading", "severity": "medium" },
    { "id": "UG041", "name": "TC/HDL Ratio High", "path": "blood_chemistry.tc_hdl_ratio.value", "operator": "<", "threshold": 6, "action": "loading", "severity": "medium" },
    { "id": "UG042", "name": "Creatinine Moderate", "path": "blood_chemistry.serum_creatinine.value", "operator": "<", "threshold": 1.5, "action": "loading", "severity": "medium" },
    { "id": "UG043", "name": "RBC Count Low", "path": "hematology.rbc_count.value", "operator": ">", "threshold": 3.5, "action": "loading", "severity": "medium" },
    { "id": "UG044", "name": "Hemoglobin Critical", "path": "hematology.hemoglobin.value", "operator": ">", "threshold": 6, "action": "decline", "severity": "critical" },
    { "id": "UG045", "name": "Fasting Glucose Very High", "path": "blood_chemistry.fasting_glucose.value", "operator": "<", "threshold": 200, "action": "refer", "severity": "high" },
    { "id": "UG046", "name": "HbA1c Diabetic Range", "path": "blood_chemistry.hba1c.value", "operator": "<", "threshold": 8, "action": "refer", "severity": "high" },
    { "id": "UG047", "name": "Creatinine Elevated", "path": "blood_chemistry.serum_creatinine.value", "operator": "<", "threshold": 2.0, "action": "refer", "severity": "high" },
    { "id": "UG048", "name": "BMI Severely Obese", "path": "physical_exam.bmi.value", "operator": "<", "threshold": 35, "action": "loading", "severity": "high" },
    { "id": "UG049", "name": "Blood Pressure Systolic High", "path": "physical_exam.blood_pressure.systolic.value", "operator": "<", "threshold": 160, "action": "refer", "severity": "high" },
    { "id": "UG050", "name": "Triglycerides Very High", "path": "blood_chemistry.triglycerides.value", "operator": "<", "threshold": 500, "action": "decline", "severity": "critical" }
  ]
}
