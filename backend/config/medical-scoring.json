{
  "version": "2.0.0",
  "description": "Medical Risk Scoring Configuration — Hybrid TeleMER Underwriting (Phase 1)",
  "components": {
    "medical_parameters": {
      "weight": 35,
      "metrics": {
        "bmi": { "weight": 5, "operator": "range", "range_low": 18.5, "range_high": 24.9, "excellent": 22, "good": 25, "fair": 30, "poor": 35 },
        "blood_pressure_systolic": { "weight": 5, "operator": "<", "excellent": 120, "good": 130, "fair": 140, "poor": 160 },
        "fasting_glucose": { "weight": 4, "operator": "<", "excellent": 100, "good": 110, "fair": 126, "poor": 200 },
        "hba1c": { "weight": 4, "operator": "<", "excellent": 5.6, "good": 6.0, "fair": 6.5, "poor": 8.0 },
        "tc_hdl_ratio": { "weight": 3, "operator": "<", "excellent": 3.5, "good": 4.5, "fair": 5.5, "poor": 7.0 },
        "sgpt_alt": { "weight": 3, "operator": "<", "excellent": 40, "good": 56, "fair": 80, "poor": 120 },
        "serum_creatinine": { "weight": 3, "operator": "<", "excellent": 1.0, "good": 1.3, "fair": 1.5, "poor": 2.0 },
        "ecg": { "weight": 4, "type": "categorical", "scores": { "normal": 4, "borderline": 2, "abnormal": 1 } },
        "hemoglobin": { "weight": 2, "operator": ">", "excellent": 14, "good": 13, "fair": 11, "poor": 9 },
        "urine_protein": { "weight": 2, "type": "categorical", "scores": { "nil": 2, "trace": 1.5, "positive": 0.5 } }
      }
    },
    "lifestyle_risk": {
      "weight": 25,
      "raw_max": 18,
      "note": "occupation_hazard and exercise removed — not captured in TeleMER form. Points redistributed to extractable sub-factors.",
      "metrics": {
        "smoking":         { "weight": 8, "type": "categorical", "scores": { "never": 8, "former_gt5": 6, "former_lt5": 3, "current": 0 } },
        "alcohol":         { "weight": 6, "type": "categorical", "scores": { "never": 6, "occasional": 5, "regular": 2, "heavy": 0 } },
        "tobacco_chewing": { "weight": 4, "type": "categorical", "scores": { "never": 4, "former": 2, "current": 0 } }
      }
    },
    "medical_history": {
      "weight": 20,
      "raw_max": 13,
      "metrics": {
        "pre_existing_conditions": { "weight": 9, "note": "Severity-tier based — see engine" },
        "hospitalizations":        { "weight": 2 },
        "systemic_conditions":     { "weight": 2 }
      }
    },
    "clinical_correlation": {
      "weight": 20,
      "raw_max": 15,
      "metrics": {
        "drug_condition_match":  { "weight": 5 },
        "multi_system_findings": { "weight": 5 },
        "cardiovascular_risk":   { "weight": 5 }
      }
    },
    "cardiovascular": {
      "weight": 15,
      "note": "Standalone domain — HTN and cardiac history. Direct score, no normalisation needed.",
      "metrics": {
        "htn_cardiac_status": { "weight": 15 }
      }
    },
    "surgical_gi": {
      "weight": 5,
      "note": "Surgical history and GI disorders. Direct score.",
      "metrics": {
        "surgical_gi_status": { "weight": 5 }
      }
    },
    "family_history": {
      "weight": 5,
      "note": "First-degree family history of hereditary conditions. Direct score.",
      "metrics": {
        "family_history_status": { "weight": 5 }
      }
    },
    "documentation_quality": {
      "weight": 10,
      "phase": 2,
      "note": "Phase 2 — deferred. Contradiction matrix result will feed into consistency sub-factor.",
      "metrics": {
        "completeness":    { "weight": 4 },
        "module_coverage": { "weight": 2 },
        "consistency":     { "weight": 4 }
      }
    }
  },
  "phase1_max": 90,
  "phase1_scale_multiplier": 1.1111,
  "grade_mapping": {
    "A+": { "min": 90 },
    "A":  { "min": 80 },
    "B+": { "min": 70 },
    "B":  { "min": 60 },
    "C":  { "min": 50 },
    "D":  { "min": 0 }
  },
  "decision_mapping": {
    "accept_standard":    { "min_score": 80 },
    "accept_with_loading":{ "min_score": 65, "loading_per_point": 5 },
    "refer":              { "min_score": 50 },
    "decline":            { "min_score": 0 }
  }
}
