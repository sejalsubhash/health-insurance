{
  "version": "1.0.0",
  "description": "Medical Risk Scoring Configuration — Insurance Underwriting",
  "components": {
    "medical_parameters": {
      "weight": 35,
      "metrics": {
        "bmi": { "weight": 5, "operator": "range", "range_low": 18.5, "range_high": 24.9, "excellent": 22, "good": 25, "fair": 30, "poor": 35 },
        "blood_pressure_systolic": { "weight": 5, "operator": "<", "excellent": 120, "good": 130, "fair": 140, "poor": 160 },
        "fasting_glucose": { "weight": 4, "operator": "<", "excellent": 100, "good": 110, "fair": 126, "poor": 200 },
        "hba1c": { "weight": 4, "operator": "<", "excellent": 5.6, "good": 6.0, "fair": 6.5, "poor": 8.0 },
        "tc_hdl_ratio": { "weight": 3, "operator": "<", "excellent": 3.5, "good": 4.5, "fair": 5.5, "poor": 7.0 },
        "sgpt_alt": { "weight": 3, "operator": "<", "excellent": 40, "good": 56, "fair": 80, "poor": 120 },
        "serum_creatinine": { "weight": 3, "operator": "<", "excellent": 1.0, "good": 1.3, "fair": 1.5, "poor": 2.0 },
        "ecg": { "weight": 4, "type": "categorical", "scores": { "normal": 4, "borderline": 2, "abnormal": 1 } },
        "hemoglobin": { "weight": 2, "operator": ">", "excellent": 14, "good": 13, "fair": 11, "poor": 9 },
        "urine_protein": { "weight": 2, "type": "categorical", "scores": { "nil": 2, "trace": 1.5, "positive": 0.5 } }
      }
    },
    "lifestyle_risk": {
      "weight": 20,
      "metrics": {
        "smoking": { "weight": 7, "type": "categorical", "scores": { "never": 7, "former": 4, "current": 1 } },
        "alcohol": { "weight": 5, "type": "categorical", "scores": { "never": 5, "occasional": 4, "regular": 2, "heavy": 0.5 } },
        "tobacco_chewing": { "weight": 3, "type": "categorical", "scores": { "never": 3, "former": 1.5, "current": 0.5 } },
        "occupation_hazard": { "weight": 3, "type": "categorical", "scores": { "none": 3, "low": 2.5, "moderate": 1.5, "high": 0.5 } },
        "exercise": { "weight": 2, "type": "categorical", "scores": { "daily": 2, "regular": 1.5, "occasional": 1, "none": 0.5 } }
      }
    },
    "medical_history": {
      "weight": 15,
      "metrics": {
        "pre_existing_conditions": { "weight": 7 },
        "family_history": { "weight": 4 },
        "hospitalizations": { "weight": 2 },
        "surgical_history": { "weight": 2 }
      }
    },
    "clinical_correlation": {
      "weight": 15,
      "metrics": {
        "drug_condition_match": { "weight": 5 },
        "multi_system_findings": { "weight": 5 },
        "cardiovascular_risk": { "weight": 5 }
      }
    },
    "documentation_quality": {
      "weight": 15,
      "metrics": {
        "completeness": { "weight": 8 },
        "module_coverage": { "weight": 4 },
        "consistency": { "weight": 3 }
      }
    }
  },
  "grade_mapping": {
    "A+": { "min": 90 },
    "A": { "min": 80 },
    "B+": { "min": 70 },
    "B": { "min": 60 },
    "C": { "min": 50 },
    "D": { "min": 0 }
  },
  "decision_mapping": {
    "accept_standard": { "min_score": 80 },
    "accept_with_loading": { "min_score": 65, "loading_per_point": 5 },
    "refer": { "min_score": 50 },
    "decline": { "min_score": 0 }
  }
}
